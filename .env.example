# =============================================================================
# DEEP RESEARCH ANALYST AGENT — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys before running.
#
# Required API Keys:
#   1. OPENAI_API_KEY     → https://platform.openai.com/api-keys
#   2. TAVILY_API_KEY     → https://app.tavily.com  (free tier: 1k req/month)
#   3. NEWS_API_KEY       → https://newsapi.org/register  (free tier: 100 req/day)
#   4. ALPHA_VANTAGE_KEY  → https://www.alphavantage.co/support/#api-key  (free)
# =============================================================================

# --- LLM: AICC Gateway (gpt-4o via api.ai.cc) — highest priority ---
AICCAPI_KEY=sk-...

# --- Web Search: Tavily (required for research actions) ---
TAVILY_API_KEY=tvly-...

# --- News API: newsapi.org (required for news-based research) ---
NEWS_API_KEY=...

# --- Financial Data: Alpha Vantage (required for financial/stock analysis) ---
ALPHA_VANTAGE_KEY=...

# --- Agent Settings ---
LOG_LEVEL=info                            # trace | debug | info | warn | error
PORT=3000                                 # REST API port
REPORTS_DIRECTORY=./reports              # Where to save generated reports
REQUEST_TIMEOUT=15000                    # API timeout in ms
MAX_RETRIES=3                            # Max retry attempts for failed requests
RETRY_DELAY=1000                         # Base retry delay in ms